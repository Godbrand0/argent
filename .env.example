# ============================================================
# LiquidMind — Environment Variables
# Copy to .env and fill in any missing values.
# ============================================================

# ------------------------------------------------------------
# Network
# ------------------------------------------------------------
STELLAR_NETWORK=testnet
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# ------------------------------------------------------------
# Asset Contracts (Stellar Asset Contracts, testnet)
# ------------------------------------------------------------

# Native XLM — Stellar Asset Contract wrapping the native asset
XLM_SAC_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# USDC — Circle testnet (issuer: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5)
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# ------------------------------------------------------------
# Protocol Contracts (populated by deploy.sh)
# ------------------------------------------------------------
VAULT_CONTRACT_ID=
VUSDC_CONTRACT_ID=
ZK_VERIFIER_CONTRACT_ID=

# ------------------------------------------------------------
# Agent
# ------------------------------------------------------------
AGENT_SECRET_KEY=                    # Stellar keypair for the agent (never commit)
LOOP_INTERVAL_MS=5000
HEARTBEAT_INTERVAL=60                # ledgers between heartbeats (~5 min)
SCAN_INTERVAL_MS=10000
MIN_PROFIT_THRESHOLD=0.02            # minimum discount before bidder bids (2%)

# ------------------------------------------------------------
# ZK circuit artifacts (relative to /agent)
# ------------------------------------------------------------
HF_WASM_PATH=../circuits/health_factor/health_factor_js/health_factor.wasm
HF_ZKEY_PATH=../circuits/health_factor/hf_final.zkey
PA_WASM_PATH=../circuits/price_attestation/price_attestation_js/price_attestation.wasm
PA_ZKEY_PATH=../circuits/price_attestation/pa_final.zkey
AP_WASM_PATH=../circuits/auction_price/auction_price_js/auction_price.wasm
AP_ZKEY_PATH=../circuits/auction_price/ap_final.zkey

# ------------------------------------------------------------
# x402 Data API server (pnpm start:server inside /agent)
# ------------------------------------------------------------
SERVER_PAYMENT_ADDRESS=            # G... address that receives x402 payments (can reuse AGENT_OWNER_ADDRESS)
PORT=4000

# ------------------------------------------------------------
# Frontend (prefix NEXT_PUBLIC_ for browser visibility)
# These mirror the contract IDs above.
# ------------------------------------------------------------
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

NEXT_PUBLIC_XLM_SAC_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC
NEXT_PUBLIC_USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

NEXT_PUBLIC_VAULT_CONTRACT_ID=       # set after deploy.sh
NEXT_PUBLIC_VUSDC_CONTRACT_ID=       # set after deploy.sh
